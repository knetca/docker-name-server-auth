# docker-name-server-auth — environment configuration
# Copy to .env and fill in values. .env is never committed.

# --- Alpine base tag ---
# Both images (nsd, nsd-manager) are built from this tag.
# Update here to rebuild all images on the same base.
ALPINE_TAG=3.20

# --- Timezone ---
TZ=America/Toronto

# --- Zone repo ---
# SSH URL of the knet-zones repository in Azure DevOps.
ZONES_REPO=git@ssh.github.com/myorg/zone-repo.git

# Branch to track
ZONES_BRANCH=main

# Cron schedule for zone polling (default: every 5 minutes)
ZONES_CRON=*/5 * * * *
